    {
      "id": "model-routing",
      "title": "Model Routing",
      "cards": [
        {
          "heading": "Complexity-Based Tier Selection",
          "content": [
            {
              "type": "paragraph",
              "html": "Every request is scored on a 0\u2013100 complexity scale. The router selects the most cost-effective model tier that can handle the task."
            },
            {
              "type": "table",
              "headers": ["Score", "Tier", "Cost Range"],
              "rows": [
                ["0\u201330", "Lite", "$0.15\u2013$0.25 / M tokens"],
                ["31\u201360", "Flash", "$0.50\u2013$3.00 / M tokens"],
                ["61\u201385", "Pro", "$2.50\u2013$15.00 / M tokens"],
                ["86\u2013100", "Pro-Extended", "$5.00\u2013$30.00 / M tokens"]
              ]
            },
            {
              "type": "paragraph",
              "html": "Scoring heuristics include prompt length, domain keywords, code block presence, and multi-step indicators.",
              "style": "margin-top:.6rem;font-size:.85rem"
            }
          ]
        }
      ]
    },
    {
      "id": "concepts",
      "title": "Key Concepts",
      "grid": "grid-2",
      "cards": [
        {
          "heading": "Issue = Conversation",
          "content": [
            {
              "type": "paragraph",
              "html": "Each GitHub issue maps to a persistent AI conversation. Comment again to continue where you left off."
            }
          ]
        },
        {
          "heading": "Git = Memory",
          "content": [
            {
              "type": "paragraph",
              "html": "Session transcripts are committed to the repo in JSONL format. The agent has full recall of every prior exchange."
            }
          ]
        },
        {
          "heading": "Actions = Runtime",
          "content": [
            {
              "type": "paragraph",
              "html": "GitHub Actions is the only compute layer. No servers, no containers, no external services."
            }
          ]
        },
        {
          "heading": "Dispatch = Routing",
          "content": [
            {
              "type": "paragraph",
              "html": "A <code>dispatch.yaml</code> config maps issue labels to specialist agents and execution modes."
            }
          ]
        }
      ]
    },
    {
      "id": "lifecycle",
      "title": "Workflow Lifecycle",
      "cards": [
        {
          "heading": "Issue \u2192 Dispatch \u2192 Agent(s) \u2192 Commit \u2192 Reply",
          "content": [
            {
              "type": "lifecycle",
              "steps": ["Issue Event", "Label Dispatch", "Route to Specialist(s)", "Agent Process", "Save State", "Post Reply"]
            },
            {
              "type": "paragraph",
              "html": "When you comment with a <code>~</code> prefix, a GitHub Actions workflow dispatches to the matching specialist agent(s), which read your message, think, respond, and commit their work \u2014 all without leaving GitHub."
            }
          ]
        }
      ]
    },
