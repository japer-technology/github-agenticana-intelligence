  "sections": [
    {
      "id": "about",
      "title": "About",
      "cards": [
        {
          "heading": "What Is Agenticana Intelligence?",
          "content": [
            {
              "type": "paragraph",
              "html": "Agenticana Intelligence extends <a class=\"link\" href=\"https://github.com/japer-technology/github-minimum-intelligence\" target=\"_blank\" rel=\"noopener\">GitHub Minimum Intelligence</a> with a constellation of <strong>20 specialist agents</strong>, each with a distinct domain, model tier, and skill set \u2014 from security auditing to frontend development to architecture debates."
            },
            {
              "type": "paragraph",
              "html": "Comment with a <code>~</code> prefix on any GitHub issue to activate Agenticana. The system dispatches your request to the right specialist (or multiple specialists) automatically."
            }
          ]
        }
      ]
    },
