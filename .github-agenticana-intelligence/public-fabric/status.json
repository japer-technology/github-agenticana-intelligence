    {
      "id": "execution-modes",
      "title": "Execution Modes",
      "grid": "grid-3",
      "cards": [
        {
          "heading": "Single",
          "content": [
            { "type": "paragraph", "html": "One specialist handles the request end-to-end. The default mode for most tasks." }
          ]
        },
        {
          "heading": "Swarm",
          "content": [
            { "type": "paragraph", "html": "Multiple specialists work in parallel on different aspects of the same request. Used for reviews and full-stack tasks." }
          ]
        },
        {
          "heading": "Simulacrum",
          "content": [
            { "type": "paragraph", "html": "Structured multi-agent debate producing Architecture Decision Records (ADRs). Used for architecture-level discussions." }
          ]
        }
      ]
